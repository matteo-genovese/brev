---
const features = [
  {
    title: 'Own the domain',
    description: 'Use your custom domains for memorable, brand-safe short links.',
  },
  {
    title: 'Ship anywhere',
    description: 'Self-host with Docker or let Brev Cloud handle infra, SSL, backups, and scaling.',
  },
  {
    title: 'Work from CLI',
    description: 'Create, list, inspect, and delete links without leaving the terminal.',
  },
  {
    title: 'Track the signal',
    description: 'Redirects include click tracking so every shared link stays measurable.',
  },
];

const steps = [
  {
    code: '01',
    title: 'Deploy',
    description: 'Run the open-source stack with PostgreSQL, FastAPI, Caddy, and the React dashboard.',
  },
  {
    code: '02',
    title: 'Connect',
    description: 'Bring a custom domain, choose a slug, and keep every link under your control.',
  },
  {
    code: '03',
    title: 'Share',
    description: 'Use the CLI, API, or dashboard to publish short links and monitor clicks.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Brev is a minimal open-source URL shortener for custom domains, self-hosting, CLI workflows, and Brev Cloud."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://brevl.ink" />
    <meta property="og:title" content="Brev — Your domain, your links, your way" />
    <meta property="og:description" content="A minimal URL shortener for self-hosted and cloud custom domains." />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="apple-touch-icon" href="/favicon-64.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@500&display=swap"
      rel="stylesheet"
    />
    <title>Brev — Your domain, your links, your way</title>
    <style>
      :root {
        color-scheme: light;
        --navy: #071936;
        --navy-muted: #38516f;
        --beige: #efe6d4;
        --beige-soft: #f8f1e6;
        --sand: #d9c5a5;
        --line: rgba(7, 25, 54, 0.14);
        font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        min-height: 100vh;
        margin: 0;
        background:
          radial-gradient(circle at top left, rgba(217, 197, 165, 0.72), transparent 34rem),
          linear-gradient(135deg, var(--beige-soft) 0%, var(--beige) 54%, #e3d2b7 100%);
        color: var(--navy);
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .serif {
        font-family: 'Instrument Serif', Georgia, serif;
      }

      .mono {
        font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, monospace;
      }

      .shell {
        width: min(1120px, calc(100% - 40px));
        margin: 0 auto;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid var(--line);
        background: rgba(248, 241, 230, 0.78);
        backdrop-filter: blur(18px);
      }

      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 72px;
        gap: 24px;
      }

      .brand,
      .nav-links,
      .nav-actions {
        display: flex;
        align-items: center;
      }

      .brand {
        gap: 12px;
        font-weight: 800;
        letter-spacing: 0.02em;
      }

      .brand img {
        width: 34px;
        height: 34px;
      }

      .nav-links {
        gap: 28px;
        color: var(--navy-muted);
        font-size: 0.9rem;
      }

      .nav-links a:hover {
        color: var(--navy);
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 22px;
        border: 1px solid var(--navy);
        border-radius: 999px;
        font-weight: 700;
        transition:
          transform 180ms ease,
          box-shadow 180ms ease,
          background 180ms ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button.primary {
        background: var(--navy);
        box-shadow: 0 18px 36px rgba(7, 25, 54, 0.2);
        color: var(--beige-soft);
      }

      .button.secondary {
        background: rgba(255, 250, 241, 0.4);
        color: var(--navy);
      }

      .hero {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
        align-items: center;
        gap: 56px;
        padding: 92px 0 80px;
      }

      .hero::before,
      .hero::after {
        position: absolute;
        border: 1px solid rgba(7, 25, 54, 0.12);
        content: '';
        pointer-events: none;
      }

      .hero::before {
        top: 64px;
        right: 18%;
        width: 180px;
        height: 180px;
        border-radius: 50%;
      }

      .hero::after {
        right: 2%;
        bottom: 112px;
        width: 76px;
        height: 76px;
        transform: rotate(45deg);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 22px;
        color: var(--navy-muted);
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .eyebrow::before {
        width: 42px;
        height: 1px;
        background: var(--navy);
        content: '';
      }

      h1 {
        margin: 0;
        font-size: clamp(4.4rem, 10.6vw, 9.75rem);
        line-height: 0.77;
        letter-spacing: -0.02em;
        text-wrap: balance;
      }

      .hero-copy {
        max-width: 560px;
        margin: 30px 0 0;
        color: var(--navy-muted);
        font-size: clamp(1.05rem, 2vw, 1.3rem);
        line-height: 1.7;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 34px;
      }

      .mini-proof {
        display: flex;
        flex-wrap: wrap;
        gap: 18px;
        margin-top: 44px;
        color: var(--navy-muted);
        font-size: 0.9rem;
      }

      .mini-proof span {
        padding-left: 16px;
        border-left: 1px solid var(--line);
      }

      .card {
        position: relative;
        z-index: 1;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 34px;
        background: rgba(255, 250, 241, 0.54);
        box-shadow: 0 28px 90px rgba(7, 25, 54, 0.16);
      }

      .preview {
        padding: 28px;
      }

      .preview-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 42px;
      }

      .pill {
        padding: 8px 12px;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: var(--navy-muted);
        font-size: 0.78rem;
      }

      .link-line {
        display: grid;
        grid-template-columns: 42px 1fr;
        align-items: start;
        gap: 16px;
        padding: 20px 0;
        border-top: 1px solid var(--line);
      }

      .link-line:last-child {
        border-bottom: 1px solid var(--line);
      }

      .number {
        color: var(--sand);
        font-weight: 800;
      }

      .link-line strong {
        display: block;
        margin-bottom: 8px;
        font-size: 1.05rem;
      }

      .link-line p {
        margin: 0;
        color: var(--navy-muted);
        line-height: 1.55;
      }

      .terminal {
        margin: 26px 0 0;
        padding: 18px;
        border-radius: 20px;
        background: var(--navy);
        color: var(--beige-soft);
        font-size: 0.84rem;
        line-height: 1.85;
      }

      .terminal span {
        color: var(--sand);
      }

      section {
        padding: 74px 0;
      }

      .section-head {
        display: grid;
        grid-template-columns: 0.8fr 1.2fr;
        align-items: end;
        gap: 44px;
        margin-bottom: 30px;
      }

      .section-kicker {
        color: var(--navy-muted);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      h2 {
        margin: 10px 0 0;
        font-size: clamp(2.4rem, 5vw, 5rem);
        line-height: 0.9;
        letter-spacing: -0.01em;
      }

      .section-head p {
        margin: 0;
        color: var(--navy-muted);
        font-size: 1.06rem;
        line-height: 1.75;
      }

      .feature-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 30px;
        background: rgba(255, 250, 241, 0.3);
      }

      .feature {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 252px;
        padding: 28px;
        border-right: 1px solid var(--line);
      }

      .feature:last-child {
        border-right: 0;
      }

      .feature h3 {
        margin: 0;
        font-size: 1.25rem;
        letter-spacing: -0.03em;
      }

      .feature p {
        margin: 22px 0 0;
        color: var(--navy-muted);
        line-height: 1.65;
      }

      .feature-mark {
        display: grid;
        width: 38px;
        height: 38px;
        place-items: center;
        border: 1px solid var(--navy);
        border-radius: 50%;
      }

      .steps {
        display: grid;
        gap: 16px;
      }

      .step {
        display: grid;
        grid-template-columns: 120px 1fr 1.1fr;
        align-items: center;
        gap: 28px;
        padding: 28px;
        border: 1px solid var(--line);
        border-radius: 26px;
        background: rgba(255, 250, 241, 0.36);
      }

      .step-code {
        color: var(--sand);
        font-size: 2.2rem;
        font-weight: 800;
      }

      .step h3 {
        margin: 0;
        font-size: 1.55rem;
        letter-spacing: -0.04em;
      }

      .step p {
        margin: 0;
        color: var(--navy-muted);
        line-height: 1.65;
      }

      .pricing {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
      }

      .price-card {
        padding: 34px;
        border: 1px solid var(--line);
        border-radius: 30px;
        background: rgba(255, 250, 241, 0.42);
      }

      .price-card.dark {
        background: var(--navy);
        color: var(--beige-soft);
      }

      .price-card h3 {
        margin: 0 0 22px;
        font-size: 1.25rem;
      }

      .price {
        font-size: clamp(3rem, 6vw, 5.8rem);
        font-weight: 800;
        line-height: 0.85;
        letter-spacing: -0.07em;
      }

      .price-note {
        margin: 16px 0 28px;
        color: var(--navy-muted);
      }

      .dark .price-note,
      .dark li {
        color: rgba(248, 241, 230, 0.72);
      }

      ul {
        margin: 0;
        padding: 0;
        list-style: none;
      }

      li {
        padding: 10px 0;
        border-top: 1px solid rgba(127, 105, 73, 0.18);
        color: var(--navy-muted);
      }

      .dark li {
        border-color: rgba(248, 241, 230, 0.16);
      }

      .cta {
        padding-bottom: 104px;
        text-align: center;
      }

      .cta-box {
        position: relative;
        overflow: hidden;
        padding: 58px 28px;
        border-radius: 36px;
        background: var(--navy);
        color: var(--beige-soft);
      }

      .cta-box::before {
        position: absolute;
        inset: 18px;
        border: 1px solid rgba(248, 241, 230, 0.18);
        border-radius: 28px;
        content: '';
        pointer-events: none;
      }

      .cta h2 {
        position: relative;
        margin-bottom: 22px;
      }

      .cta p {
        position: relative;
        max-width: 560px;
        margin: 0 auto 30px;
        color: rgba(248, 241, 230, 0.72);
        line-height: 1.7;
      }

      .cta .button {
        position: relative;
        border-color: var(--beige-soft);
        background: var(--beige-soft);
        color: var(--navy);
      }

      footer {
        padding: 34px 0;
        border-top: 1px solid var(--line);
        color: var(--navy-muted);
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        font-size: 0.92rem;
      }

      .footer-links {
        display: flex;
        gap: 22px;
      }

      @media (max-width: 900px) {
        .nav-links {
          display: none;
        }

        .hero,
        .section-head,
        .pricing {
          grid-template-columns: 1fr;
        }

        .hero {
          padding-top: 58px;
        }

        .feature-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .feature:nth-child(2) {
          border-right: 0;
        }

        .feature:nth-child(-n + 2) {
          border-bottom: 1px solid var(--line);
        }

        .step {
          grid-template-columns: 1fr;
          gap: 12px;
        }
      }

      @media (max-width: 620px) {
        .shell {
          width: min(100% - 28px, 1120px);
        }

        .nav-actions {
          display: none;
        }

        h1 {
          font-size: clamp(3.7rem, 20vw, 6.2rem);
        }

        .hero::before,
        .hero::after {
          display: none;
        }

        .feature-grid {
          grid-template-columns: 1fr;
        }

        .feature,
        .feature:nth-child(2) {
          border-right: 0;
          border-bottom: 1px solid var(--line);
        }

        .feature:last-child {
          border-bottom: 0;
        }

        .footer-inner {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <nav class="nav">
      <div class="shell nav-inner">
        <a href="/" class="brand" aria-label="Brev home">
          <img src="/logo-32.png" alt="" />
          <span>Brev</span>
        </a>

        <div class="nav-links" aria-label="Primary navigation">
          <a href="#features">Features</a>
          <a href="#workflow">Workflow</a>
          <a href="#pricing">Pricing</a>
          <a href="https://github.com/matteo-genovese/brev" target="_blank" rel="noreferrer">GitHub</a>
        </div>

        <div class="nav-actions">
          <a class="button primary" href="/app/login">Get started</a>
        </div>
      </div>
    </nav>

    <main>
      <header class="shell hero">
        <div>
          <div class="eyebrow">Open-source URL shortener</div>
          <h1 class="serif">Short links,<br />long control.</h1>
          <p class="hero-copy">
            Brev gives every team a quieter way to manage links: custom domains, click tracking, a clean API,
            and a CLI that feels native to your workflow.
          </p>

          <div class="hero-actions">
            <a class="button primary" href="/app/login">Start shortening</a>
            <a class="button secondary" href="https://github.com/matteo-genovese/brev" target="_blank" rel="noreferrer">
              View source
            </a>
          </div>

          <div class="mini-proof" aria-label="Brev highlights">
            <span>MIT licensed</span>
            <span>Self-hosted first</span>
            <span>Brev Cloud soon</span>
          </div>
        </div>

        <aside class="card preview" aria-label="Brev product preview">
          <div class="preview-top">
            <span class="pill mono">brevl.ink/go</span>
            <span class="pill">42 clicks</span>
          </div>

          <div class="link-line">
            <span class="number">01</span>
            <div>
              <strong>Your domain</strong>
              <p>Point a custom domain at Brev and keep every shared URL on-brand.</p>
            </div>
          </div>

          <div class="link-line">
            <span class="number">02</span>
            <div>
              <strong>Your stack</strong>
              <p>PostgreSQL auth, FastAPI, Caddy auto SSL, and no vendor lock-in.</p>
            </div>
          </div>

          <div class="terminal mono">
            <span>$</span> brev create https://example.com --slug go<br />
            <span>→</span> https://brevl.ink/go
          </div>
        </aside>
      </header>

      <section id="features" class="shell">
        <div class="section-head">
          <div>
            <span class="section-kicker">Features</span>
            <h2 class="serif">Minimal by design.</h2>
          </div>
          <p>
            Everything from the README is focused into one product promise: own the link layer, whether you run
            it yourself or use hosted infrastructure.
          </p>
        </div>

        <div class="feature-grid">
          {
            features.map((feature) => (
              <article class="feature">
                <div class="feature-mark">/</div>
                <div>
                  <h3>{feature.title}</h3>
                  <p>{feature.description}</p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section id="workflow" class="shell">
        <div class="section-head">
          <div>
            <span class="section-kicker">Workflow</span>
            <h2 class="serif">Three clear moves.</h2>
          </div>
          <p>
            From local deploys to managed cloud domains, Brev keeps the path from long URL to trackable short
            link intentionally simple.
          </p>
        </div>

        <div class="steps">
          {
            steps.map((step) => (
              <article class="step">
                <span class="step-code mono">{step.code}</span>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section id="pricing" class="shell">
        <div class="section-head">
          <div>
            <span class="section-kicker">Pricing</span>
            <h2 class="serif">Open source first.</h2>
          </div>
          <p>
            Use the MIT-licensed stack forever, or choose Brev Cloud when you want the domain setup and
            infrastructure handled for you.
          </p>
        </div>

        <div class="pricing">
          <article class="price-card">
            <h3>Self-hosted</h3>
            <div class="price">$0</div>
            <p class="price-note">Forever. Docker compose, PostgreSQL, FastAPI, dashboard, and CLI.</p>
            <ul>
              <li>Unlimited links on your own infrastructure</li>
              <li>Custom domains with Caddy auto SSL</li>
              <li>OpenAPI docs and CLI access</li>
            </ul>
          </article>

          <article class="price-card dark">
            <h3>Brev Cloud · coming soon</h3>
            <div class="price">$5</div>
            <p class="price-note">One-time per domain. Managed DNS, SSL, deploys, backups, and scaling.</p>
            <ul>
              <li>No infrastructure to maintain</li>
              <li>Bring your domain to brevl.ink</li>
              <li>Hosted updates and operational support</li>
            </ul>
          </article>
        </div>
      </section>

      <section class="shell cta">
        <div class="cta-box">
          <h2 class="serif">Make every link feel intentional.</h2>
          <p>Install the CLI, self-host the stack, or join Brev Cloud when it opens. Your domain, your links, your way.</p>
          <a class="button" href="/app/login">Get started</a>
        </div>
      </section>
    </main>

    <footer>
      <div class="shell footer-inner">
        <span>© 2026 Brev. MIT licensed.</span>
        <div class="footer-links">
          <a href="/docs">API docs</a>
          <a href="https://github.com/matteo-genovese/brev" target="_blank" rel="noreferrer">GitHub</a>
          <a href="https://matteogenovese.com" target="_blank" rel="noreferrer">Author</a>
        </div>
      </div>
    </footer>
  </body>
</html>
