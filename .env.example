# ── Brev ──────────────────────────────────────────────────────────────
# Copia in .env e modifica:
#   cp .env.example .env
#   docker compose up -d

# Obbligatorie
JWT_SECRET=change-me-in-production          # genera con: openssl rand -hex 32
DB_PASSWORD=change-me                       # genera con: openssl rand -hex 24
CADDY_EMAIL=tuo@email.com                   # per Let's Encrypt

# Opzionali
DEFAULT_DOMAIN=brevl.ink
ENVIRONMENT=development
SECURE_COOKIES=false
DOCS_ENABLED=true
DEBUG=false
CORS_ORIGINS=["https://brevl.ink","https://app.brevl.ink"]
CNAME_TARGET=proxy.brevl.ink.

# Stripe (solo Brev Cloud — ignora per self-hosted)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
