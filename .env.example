# Brev
# Copia questo file in .env e modifica i valori prima di avviare:
#   cp .env.example .env
#   openssl rand -hex 32   # JWT_SECRET
#   openssl rand -hex 24   # DB_PASSWORD

# Segreti obbligatori
JWT_SECRET=change-me-in-production
DB_PASSWORD=change-me

# Docker Compose
HTTP_PORT=80
BREV_DATA=./data
BREV_NETWORK_NAME=brev_net
POSTGRES_IMAGE=postgres:16-alpine
BACKEND_IMAGE=brev-backend:local
LANDING_IMAGE=brev-landing:local
DASHBOARD_IMAGE=brev-dashboard:local
CADDY_IMAGE=caddy:2-alpine

# Database
DB_USER=postgres
DB_NAME=brev

# Applicazione
DEFAULT_DOMAIN=brevl.ink
ENVIRONMENT=development
SECURE_COOKIES=false
DOCS_ENABLED=true
CLOUD_MODE=false
REQUIRE_VERIFIED_EMAIL=false
FREE_CUSTOM_DOMAINS=0
BREV_DEBUG=false
CORS_ORIGINS=["https://brevl.ink","https://app.brevl.ink"]
CNAME_TARGET=proxy.brevl.ink.

# Stripe (solo Brev Cloud, lascia vuoto per self-hosted)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
# STRIPE_SUCCESS_URL=https://brevl.ink/app/dashboard?billing=success
# STRIPE_CANCEL_URL=https://brevl.ink/app/dashboard?billing=cancelled
